# DLC Manager backoffice — environment variables.
# Copy to `.env` and tune per-environment. Never commit the real .env.

# Port the Node server listens on.
PORT=3000

# Interface to bind.
#   0.0.0.0 = exposed on all interfaces (direct access from Internet — requires firewall rule)
#   127.0.0.1 = localhost only (recommended when fronted by a reverse proxy)
HOST=127.0.0.1

# JWT signing secret. Generate with: openssl rand -hex 48
JWT_SECRET=change-me-to-a-long-random-string

# Optional overrides (defaults are fine for most deployments).
# DB_PATH=/root/app_soldes/server/dlc-manager.db
# UPLOADS_DIR=/root/app_soldes/server/uploads
